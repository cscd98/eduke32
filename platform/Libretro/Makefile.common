  $(AUDIOLIB_SRC)/xmp.cpp \
  $(AUDIOLIB_SRC)/gmtimbre.cpp

# $(AUDIOLIB_SRC)/driver_alsa.cpp \

###############################################################################
# MACT sources
###############################################################################
MACT_SRCS := \
  $(MACT_SRC)/control.cpp \
  $(MACT_SRC)/joystick.cpp \
  $(MACT_SRC)/scriplib.cpp \
  $(MACT_SRC)/animlib.cpp \
  $(MACT_SRC)/keyboard.cpp

BUILD_GLSL := \
  $(BUILD_SRC)/polymost1Vert.glsl \
  $(BUILD_SRC)/polymost1Frag.glsl

###############################################################################
# libretro-common
###############################################################################
LIBRETRO_COMMON_SRCS := \
  $(LIBRETRO_COMMON_SRC)/rthreads/rthreads.c

###############################################################################
# Aggregated list
###############################################################################
ALL_SRCS := \
  $(LIBRETRO_SRCS) \
  $(BUILD_SRCS) \
  $(GLAD_SRCS) \
  $(GAME_SRCS) \
  $(AUDIO_SRCS) \
  $(MACT_SRCS) \
  $(LIBRETRO_COMMON_SRCS)
